# Configuration Email pour SwipeTonPro
# Copiez ce fichier en .env.local et configurez les valeurs réelles

# Configuration SMTP OVH
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_PASSWORD=votre_mot_de_passe_ovh

# Adresses email d'envoi
SMTP_USER_NOREPLY=noreply@swipetonpro.com
SMTP_USER_SUPPORT=support@swipetonpro.com
SMTP_USER_TEAM=team@swipetonpro.com
SMTP_USER_ADMIN=admin@swipetonpro.com
SMTP_USER_CONTACT=contact@swipetonpro.com

# Configuration du site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=votre_cle_publique_stripe
STRIPE_SECRET_KEY=votre_cle_secrete_stripe
STRIPE_WEBHOOK_SECRET=votre_webhook_secret_stripe

# Clés Supabase
NEXT_PUBLIC_SUPABASE_URL=votre_url_supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_cle_anon_supabase
SUPABASE_SERVICE_ROLE_KEY=votre_cle_service_supabase

# Tokens sécurité API (dev/staging)
INTERNAL_EMAIL_API_TOKEN=votre_token_interne_email
SECURITY_AUDIT_TOKEN=votre_token_audit_securite
SETUP_SECRET=votre_setup_secret
SETUP_ADMIN_TOKEN=votre_setup_admin_token
SETUP_ADMIN_EMAIL=admin@swipetonpro.fr
SETUP_ADMIN_PASSWORD=votre_mot_de_passe_bootstrap_fort
