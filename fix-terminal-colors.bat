@echo off
echo 🔧 Correction des couleurs du terminal PowerShell
echo.

echo 🎨 Options de couleurs disponibles:
echo.
echo 0A - Noir sur Vert (clair et lisible)
echo 0B - Noir sur Cyan (très lisible)  
echo 0E - Noir sur Jaune (contraste élevé)
echo 0F - Noir sur Blanc (classique)
echo 1F - Bleu sur Blanc (professionnel)
echo 2F - Vert sur Blanc (développeur)
echo.

echo 🚀 Application des couleurs...
cmd /c "color 0F"

echo.
echo ✅ Terminal reconfiguré !
echo.
echo 💡 Si les couleurs ne s'appliquent pas:
echo    1. Fermez et rouvrez PowerShell
echo    2. Ou utilisez Windows Terminal
echo    3. Ou changez les couleurs dans les paramètres du terminal
echo.

pause
