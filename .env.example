# ===========================================
# CONFIGURATION EMAIL SMTP (OVH)
# ===========================================
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=465
SMTP_SECURE=true

# Mot de passe unique pour tous les comptes email OVH
# IMPORTANT: Générer un mot de passe fort (32+ caractères)
SMTP_PASSWORD=your_smtp_password_here

# Adresses email expéditeurs
SMTP_USER_NOREPLY=noreply@swipetonpro.fr
SMTP_USER_SUPPORT=support@swipetonpro.fr
SMTP_USER_TEAM=team@swipetonpro.fr
SMTP_USER_ADMIN=admin@swipetonpro.fr
SMTP_USER_CONTACT=contact@swipetonpro.fr

# Pour nodemailer avec OVH, on utilise l'adresse email complète comme user
SMTP_USER=noreply@swipetonpro.fr

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# Dashboard Supabase > Settings > API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ===========================================
# SITE CONFIGURATION
# ===========================================
NEXT_PUBLIC_SITE_URL=https://www.swipetonpro.fr

# ===========================================
# OPENAI CONFIGURATION
# ===========================================
# Dashboard OpenAI > API keys
# IMPORTANT: Définir une limite de dépenses
OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# STRIPE CONFIGURATION
# ===========================================
# Dashboard Stripe > Developers > API keys
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# ===========================================
# INSEE API
# ===========================================
# Portail API INSEE > Mes applications
INSEE_API_KEY=your_insee_api_key_here

# ===========================================
# GITHUB TOKEN (optionnel)
# ===========================================
# GitHub > Settings > Developer settings > Personal access tokens
# Permissions minimales: repo (read only)
GITHUB_TOKEN=your_github_token_here

# ===========================================
# NOTES DE SÉCURITÉ
# ===========================================
# 1. NE JAMAIS commiter ce fichier avec des valeurs réelles
# 2. Copier ce fichier vers .env.local et remplir les valeurs
# 3. Utiliser des mots de passe forts (32+ caractères)
# 4. Rotation des secrets tous les 90 jours
# 5. Utiliser un gestionnaire de mots de passe pour stocker les secrets
